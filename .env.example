# Skyjo Server Environment Configuration
# Copy this file to .env and customize as needed.

# --- Database ---
# PostgreSQL password (used by both backend and db containers)
DB_PASSWORD=skyjo

# Full PostgreSQL connection URL (used by backend)
# If running outside Docker, override this:
# DATABASE_URL=postgres://skyjo:skyjo@localhost:5432/skyjo

# --- Auth ---
# JWT signing secret. If not set, an ephemeral secret is generated on startup
# (sessions won't survive server restart).
JWT_SECRET=

# Default admin account credentials (only used when no users exist in DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Skyjo-Change-Me-1!

# --- Server ---
# Port exposed by the frontend container
PORT=8080

# Data directory inside the backend container (for genetic model files)
# SKYJO_DATA_DIR=/var/lib/skyjo
